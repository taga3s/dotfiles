[user]
        name = taga3s
        email = 107479598+taga3s@users.noreply.github.com 
        signingkey = ~/.ssh/id_ed25519.pub

[init]
        defaultBranch = main

[commit]
        verbose = true
        gpgsign = true

[core]
        editor = nvim

[push]
        autoSetupRemote = true

[fetch]
        all = true
        prune = true

[gpg]
        format = ssh

[gpg "ssh"]
        allowedSignersFile = ~/.ssh/allowed_signers

[ghq]
        root = /Users/taga3s/my-work
